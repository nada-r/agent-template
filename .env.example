# ─────────────────────────────────────────────────────────────
# Environment configuration
# Copy to .env and fill in. NEVER commit .env - only this file.
# Every variable documented: what it is, where to get it, safe default.
# ─────────────────────────────────────────────────────────────

# ── Server ───────────────────────────────────────────────────
# Port the Fastify server listens on. Railway injects PORT automatically.
PORT=3000

# Node environment: development | production | test
NODE_ENV=development

# ── Database (uncomment when Prisma is added) ────────────────
# PostgreSQL connection string. Local: docker compose / Railway: injected.
# DATABASE_URL=postgresql://user:password@localhost:5432/dbname

# ── External APIs ────────────────────────────────────────────
# Document EVERY key: which dashboard it comes from, which scopes it needs.
# EXAMPLE_API_KEY=            # https://dashboard.example.com/keys - read-only scope

# ── Risk / operational limits (make implicit assumptions explicit) ──
# Fees, limits, and thresholds belong HERE, visible - never assumed zero in code.
# MAX_RETRY_ATTEMPTS=3
# REQUEST_TIMEOUT_MS=10000
